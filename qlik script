KALENDER_RA:
Left keep (RA_Detalje_FACT)
Load *, 
'Q' & KvartalNr & ' ' & Date(Dato,'YY') as KvartalAar,
if(floor(Dato) = floor(MånedSlut), 1,0) as MånedSlutFlag, 
if(floor(Dato) = floor(KvartalSlut), 1,0) as KvartalSlutFlag,
if(floor(Dato) = floor(AarSlut) , 1, 0)

as AarSlutFlag
;
Load *,
If(match(År, 2021,2022,2023), 'MRP_ÅR') as MRP_ÅR;
Load *, MonthEnd(Dato) as MånedSlut, QuarterEnd(Dato) as KvartalSlut, If(Year('$(s_DWHDato)')= Year(Dato), Monthend('$(s_DWHDato)',-1), YearEnd(Dato)) as AarSlut;

LOAD
            Kalender_KEY as [RA_DATO_KEY]
            ,QuarterName(Kalender_KEY) as Kvartal
            ,MonthName(Kalender_KEY) as Måned
            ,WeekName(Kalender_KEY) as Uge
            ,Ceil(Month(Kalender_KEY)/3) as KvartalNr
            ,Month(Kalender_KEY) as MånedNr
            ,Week(Kalender_KEY) as UgeNr
            ,Dato
            ,År
            ,If(Kalender_KEY>=MonthStart('$(s_DWHDato)',-3),1,0)                     as Tidsserie_3md
            ,If(Kalender_KEY>=MonthStart('$(s_DWHDato)',-6),1,0)                     as Tidsserie_6md
            ,If(Kalender_KEY>=MonthStart('$(s_DWHDato)',-12),1,0)                    as Tidsserie_12md
            ,If(Kalender_KEY>=YearStart('$(s_DWHDato)',-3),1,0)                      as Tidsserie_3år
            ,If(Kalender_KEY>=YearStart('$(s_DWHDato)',-2),1,0)                      as Tidsserie_2år
            ,If(Kalender_KEY>=YearStart('$(s_DWHDato)',-1),1,0)                      as Tidsserie_1år
            ,If(Kalender_KEY>=YearStart('$(s_DWHDato)'),1,0)                                     as AktueltÅr
            ,If(Kalender_KEY=floor(YearEnd('$(s_DWHDato)',-1)),1,0)                  as AarSlut_1år
            ,If(Kalender_KEY=floor('$(s_DWHDato)'),1,0)                                                       as AktuelDato
            ,DayNumberOfYear(Kalender_KEY)                                                                                             as Dag
            ,If(DayNumberOfYear(Kalender_KEY)<=DayNumberOfYear('$(s_DWHDato)'),'1') as YTD_FLG
            ,If(Kalender_KEY>=YearStart('$(s_DWHDato)',-1),'Indeværende og sidste år')                       as [2YR]
            ,If(Kalender_KEY>=YearStart('$(s_DWHDato)',0),'1YR')                     as [1YR]
            ,If(DayNumberOfYear(Kalender_KEY)<=DayNumberOfYear('$(s_DWHDato)'),'År til dato for valgte år') as YOY //CR.0441

Resident [TempCalendar]
order by Kalender_KEY desc;

