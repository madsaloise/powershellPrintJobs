SUB QV.QVDConcatenate(i_TableName,i_FileName,i_DeltaKey)

            if not upper(right(i_FileName,4)) = '.QVD' THEN
                         LET i_FileName = '$(i_FileName).QVD';
            endif

            LET t_MemoryRows = NoOfRows('$(i_TableName)');
            LET t_FileExist=if(FileTime('$(i_FileName)')>0,-1,0);

            if $(t_FileExist) then
                         Concatenate($(i_TableName))
                         load *
                         FROM
                         $(i_FileName)
                         (qvd)
                         where not Exists($(i_DeltaKey));
            endif
            
            LET t_MemoryRows=;
            LET t_FileExist=;
            
ENDSUB

SUB QV.QVDStore(i_TableName,i_FileName)

            if not upper(right(i_FileName,4)) = '.QVD' THEN
                         LET i_FileName = '$(i_FileName).QVD';
            endif

            LET t_QVDBeforeStore = QvdNoOfRecords ('$(i_FileName)')+0;

            if isnull(t_QVDBeforeStore) THEN
                         let t_QVDBeforeStore = 0;
            endif
            
            STORE [$(i_TableName)] INTO $(i_FileName);
            LET t_QVDAfterStore = QvdNoOfRecords ('$(i_FileName)');

            Call Qv.Trace(0,'# Table $(i_TableName) Stored into $(i_FileName) before/after: $(t_QVDBeforeStore)/$(t_QVDAfterStore)',0);
            
            LET t_QVDBeforeStore=;
            LET t_QVDAfterStore=;
            
ENDSUB

SUB QV.QVDConcatenateStore(i_TableName,i_FileName,i_DeltaKey)

            call QV.QVDConcatenate(i_TableName,i_FileName,i_DeltaKey);
            call QV.QVDStore(i_TableName,i_FileName);
            
ENDSUB

SUB QV.QVDPartition(i_TableName,i_FileName,i_DeltaKey,i_PartitionBy) 

            LOOP_PARTITIONS:
            NoConcatenate
            load distinct [$(i_PartitionBy)]
            Resident $(i_TableName)
            order by [$(i_PartitionBy)]
            ;

            for i = 0 to NoOfRows('LOOP_PARTITIONS')-1

                         LET l_Partition = Peek('$(i_PartitionBy)',i,'LOOP_PARTITIONS');
                         Call QV.Trace(1,'**     Partition by $(l_Partition)     **',0);

                         if not isnull(l_Partition) then
                                     NoConcatenate
                                     [DATALOAD_$(l_Partition)]:
                                     load *
                                     Resident $(i_TableName)
                                     where [$(i_PartitionBy)] = '$(l_Partition)'
                                     ; 

                                     LET t_MemoryRows = NoOfRows('DATALOAD_$(l_Partition)');
                                     LET t_TargetFileExist=if(FileTime('$(i_QVDDirectoryName)\$(i_FileName)_$(l_Partition).QVD')>0,1,0);

                                     IF t_MemoryRows > 0 and t_TargetFileExist then
                                                  CALL QV.QVDConcatenate('DATALOAD_$(l_Partition)','$(i_FileName)_$(l_Partition)',i_DeltaKeyName);
                                     ENDIF
                                     
                                     LET t_MemoryRows=;
                                     LET t_TargetFileExist=;
                                     
                                     Call QV.QVDStore('DATALOAD_$(l_Partition)','$(i_FileName)_$(l_Partition)');

                                     Drop Table [DATALOAD_$(l_Partition)];

                         endif
            next
            
            LET l_Partition=;
            Drop Table LOOP_PARTITIONS;

ENDSUB

