SYNTAX      : Call QV.Calendar(_startDate, _endDate, _tableName, _fieldPrefix, _lang, _type, _key)
                                                  _startDate               : First date to be included in the generated Calendar
                                                  _endDate                 : Last date to be included in the generated Calendar
                                                  _tableName               : Name of the generated Calendar Table
                                                  _FieldPrefix : Prefix to be used on all Fields
                                                  _lang                                : Language ('DK' for Danish otherwise English)
                                                  _type                                : Type of Calendar ('SMALL'|'MEDIUM'|'FULL'|'UNI')
                                                  _key                                 : Field name to be used as key towards the rest of the datamodel - It's the date field that will be used as key.

*****************************************************

*/
//call QV.IncludeScan('..\80_SCRIPTS\80_CALENDAR.qvs');

SUB QV.Calendar(_startDate, _endDate, _tableName, _fieldPrefix, _lang, _type, _key, _indexdate)
       call QV.Trace(1,'Creating Calendar - $(_tableName)',0) ;
       call QV.Trace(0,'Start date - $(_startDate)',0) ;      
       call QV.Trace(0,'End date   - $(_endDate)',0) ; 
       
       if len('$(_indexdate)') < 1 then
            let _indexdate=today();
       ENDIF

       call QV.Trace(0,'Index base date   - $(_indexdate)',0) ; 
       
       [$(_tableName) TEMP]:
       LOAD
                                     Aff_QV_Date                                                                                                                 AS [$(_key)],
                    Aff_QV_Date                                                                                                        AS [$(_fieldPrefix)Date],
                                Year(Aff_QV_Date)                                                                                                   AS [$(_fieldPrefix)Year],
                                if(NUM(MONTH(Aff_QV_Date)) < 7,
                                    1,
                                    2)                                                                                                                          AS [$(_fieldPrefix)Half-Year],
