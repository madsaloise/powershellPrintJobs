SUB QV.Calendar_Min_Max(i_FieldName, i_ReturnPrefix)

                         Min_Max_TEMP:
                         NoConcatenate
                         Load
                                     YearStart(Min(Date_Field)) as GetMinDate,
                                     YearEnd(Max(Date_Field)) as GetMaxDate;
                         Load
                                     FieldValue('$(i_FieldName)', IterNo()) as Date_Field
                         Autogenerate(1)
                                     While not IsNull(FieldValue('$(i_FieldName)', IterNo()));

                         LET $(i_ReturnPrefix).Min = peek('GetMinDate');
        LET $(i_ReturnPrefix).Max = peek('GetMaxDate');
                         
END SUB 

sub QV.Get_Min_Max(_tableName, _FieldNavn, _Return_var)
       call QV.Trace(1,'Finding Min & Max - $(_tableName).$(_FieldNavn)]',0) ;

       Get_Min_Max_TEMP:
       LOAD min([$(_FieldNavn)]) as Get_min_field,
       year(Today()) as Get_max_field
//            max([$(_FieldNavn)]) as Get_max_field
       RESIDENT [$(_tableName)];
  
       LET $(_Return_var).Max = peek('Get_max_field');
       LET $(_Return_var).Min = peek('Get_min_field');
  
       Drop table Get_Min_Max_TEMP;   

       call QV.Trace(0,'Min ($($(_Return_var).Min)) & Max ($($(_Return_var).Max)) - $(_tableName).$(_FieldNavn)]',0) ;
end sub

